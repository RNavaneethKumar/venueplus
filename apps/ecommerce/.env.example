# ─── API connection ────────────────────────────────────────────────────────────
# URL of the running @venueplus/api server
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ─── Venue ─────────────────────────────────────────────────────────────────────
# The UUID of the venue this app serves.
# For the FunZone demo seed data use the value below.
NEXT_PUBLIC_VENUE_ID=c0000000-0000-0000-0000-000000000001
