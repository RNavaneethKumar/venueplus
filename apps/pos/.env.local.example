# ─── API ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ─── Single-tenant dev (legacy) ───────────────────────────────────────────────
# Used when running on bare localhost (no subdomain).
# The UUID of the venue row in your local development database.
NEXT_PUBLIC_VENUE_ID=c0000000-0000-0000-0000-000000000001

# ─── Multi-tenant localhost dev ───────────────────────────────────────────────
# When REGISTRY_DATABASE_URL is set in the API, the frontend needs to send a
# tenant slug with every request.  On localhost (no real subdomain), set this
# to the slug of the tenant you are developing against.
#
# You have three choices — pick whichever suits your workflow:
#
# Option A — Env var (simplest, no hosts file changes)
#   Set this value and keep hitting http://localhost:3000
#   NEXT_PUBLIC_TENANT_SLUG=greenpark
#
# Option B — *.localhost subdomain (closer to production, no install needed)
#   Modern browsers (Chrome/Firefox) resolve *.localhost to 127.0.0.1 natively.
#   Start the dev server normally, then open: http://greenpark.localhost:3000
#   Leave NEXT_PUBLIC_TENANT_SLUG unset — the middleware extracts it from the hostname.
#
# Option C — /etc/hosts entry (works in all browsers/tools)
#   Add to /etc/hosts:   127.0.0.1  greenpark.localhost
#   Then open: http://greenpark.localhost:3000
#   Leave NEXT_PUBLIC_TENANT_SLUG unset.
#
# NEXT_PUBLIC_TENANT_SLUG=greenpark
