# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────

# Single-tenant (local dev) — the main application database
DATABASE_URL=postgres://postgres:password@localhost:5432/venueplus

# Multi-tenant — the central tenant registry database.
# Leave commented out to run in single-tenant mode (uses DATABASE_URL only).
# When set, every request must carry an x-tenant-slug header and the API
# routes queries to per-tenant databases looked up from this registry.
#
# REGISTRY_DATABASE_URL=postgres://postgres:password@localhost:5432/venueplus_registry

# ─── Global Admin ─────────────────────────────────────────────────────────────
# One-time secret used to seed the very first global admin account.
# POST /api/v1/global-admin/auth/seed   { email, name, password, seedSecret }
# Disable after seeding by removing this variable or setting it to a random value.
#
# GLOBAL_ADMIN_SEED_SECRET=change-me-to-a-strong-random-value

# ─── Tenant Provisioning ───────────────────────────────────────────────────────
# Superuser Postgres URL used to CREATE DATABASE for new tenants.
# Must point to a user with CREATEDB privilege.
# When absent, the "Provision new database" button is hidden in the admin UI.
#
# POSTGRES_ADMIN_URL=postgres://postgres:password@localhost:5432/postgres

# Path to the root database/ folder containing run.sql and the SQL sub-folders.
# Defaults to ../../database relative to process.cwd() (i.e. the repo root when
# running from apps/api/ via `pnpm dev`).
#
# DATABASE_SCRIPTS_PATH=/absolute/path/to/database

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In multi-tenant prod, add your wildcard subdomain pattern.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Notifications ────────────────────────────────────────────────────────────
SMS_PROVIDER=console
EMAIL_PROVIDER=console
FROM_EMAIL=noreply@venueplus.io
