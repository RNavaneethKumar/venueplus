{
  "name": "@venueplus/companion",
  "version": "1.0.0",
  "description": "VenuePlus Companion — local agent for printing, licensing, and peripheral management",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "dev": "npm run build && concurrently \"tsc --watch --preserveWatchOutput\" \"electron .\"",
    "build": "tsc",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.venueplus.companion",
    "productName": "VenuePlus Companion",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "templates",
        "to": "templates"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": true,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "electron-store": "^8.2.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^9.0.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/qrcode": "^1.5.5",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
