# =============================================================================
# VenuePlus — Environment Configuration
#
# 1. Rename this file to .env
# 2. Fill in your Neon (or other Postgres) database URLs
# 3. Run: docker compose -f docker-compose.dist.yml up -d
# =============================================================================

# ─── Ports (change if 4000/3001 are already in use on your machine) ──────────
API_PORT=4000
POS_PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
# Your main application database (Neon, Supabase, or any Postgres)
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/venueplus_demo?sslmode=require

# Central registry database (maps tenant subdomains to databases)
REGISTRY_DATABASE_URL=postgresql://user:password@host/venueplus_registry?sslmode=require

# Superuser URL for creating new tenant databases via the admin panel
# Must have CREATEDB privilege. Leave blank if not using tenant provisioning.
POSTGRES_ADMIN_URL=postgresql://user:password@host/postgres?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# ─── Global Admin ─────────────────────────────────────────────────────────────
# One-time secret to create your first admin account.
# After seeding, remove this or set it to a random value.
# Generate one: openssl rand -hex 16
GLOBAL_ADMIN_SEED_SECRET=replace-with-random-value

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001

# ─── Notifications (leave as 'console' to print to logs instead of sending) ──
SMS_PROVIDER=console
EMAIL_PROVIDER=console
FROM_EMAIL=noreply@yourdomain.com
